{
  "$schema": "https://raw.githubusercontent.com/microsoft/vcpkg-tool/main/docs/vcpkg.schema.json",
  "name": "renderer573",
  "version-string": "0.1.0",
  "description": "573Renderer - standalone AFP renderer + asset dumper for Konami IIDX/SDVX. vcpkg-driven dependency manifest.",
  "dependencies": [
    "catch2",
    "tl-expected",
    {
      "name": "imgui",
      "default-features": false,
      "features": [
        "dx9-binding",
        "win32-binding"
      ]
    },
    {
      "name": "ffmpeg",
      "default-features": false,
      "features": [
        "aom",
        "avcodec",
        "avformat",
        "swscale",
        "nvcodec",
        "vpx",
        "webp",
        "x265"
      ]
    }
  ]
}
